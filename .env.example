# .env.example
# Copy to .env for local development. Never commit .env.
# All keys here must also be declared in harness/secrets.yaml.

# ── Anthropic (required for Supervisor / Opus) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Model selection ───────────────────────────────────────────────────────────
# Reviewer: any OpenAI-compatible model via REVIEWER_MODEL + OLLAMA_BASE_URL + LLM_API_KEY
# Groq example:   REVIEWER_MODEL=ollama/llama-3.3-70b-versatile
#                 OLLAMA_BASE_URL=https://api.groq.com/openai/v1
#                 LLM_API_KEY=gsk_...
# Ollama example: REVIEWER_MODEL=ollama/llama3.1   (no LLM_API_KEY needed)
# Default (Claude Sonnet) is used when REVIEWER_MODEL is not set.
REVIEWER_MODEL=ollama/llama-3.3-70b-versatile
# Supervisor always uses Claude Opus — if ANTHROPIC_API_KEY is not set,
# supervision is skipped and the agent falls back to comment-only mode.
# SUPERVISOR_MODEL=claude-opus-4-5

# ── LLM endpoint (only needed when REVIEWER_MODEL starts with "ollama/") ──────
OLLAMA_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_...

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo-name          # e.g. acme/backend

# ── Webhook security ──────────────────────────────────────────────────────────
WEBHOOK_SECRET=change-me-to-random-32-chars

# ── Harness (used by harness_client.py to re-trigger pipelines) ───────────────
HARNESS_API_KEY=...
HARNESS_ACCOUNT_ID=...
HARNESS_ORG_ID=...
HARNESS_PROJECT_ID=...
HARNESS_PIPELINE_ID=coding-agent-pipeline

# ── Runtime ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
PORT=8000
