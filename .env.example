# .env.example
# Copy to .env for local development. Never commit .env.
# All keys here must also be declared in harness/secrets.yaml.

# ── Anthropic (required for Supervisor / Opus) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Model selection ───────────────────────────────────────────────────────────
# Reviewer: set to an Ollama model to run locally instead of Claude Sonnet
# Examples: ollama/llama3.1   ollama/deepseek-r1   ollama/qwen2.5-coder
REVIEWER_MODEL=ollama/llama3.1        # default: claude-sonnet-4-6
# Supervisor always uses Opus — do not override unless intentional
# SUPERVISOR_MODEL=claude-opus-4-5

# ── Ollama (only needed when REVIEWER_MODEL starts with "ollama/") ─────────────
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo-name          # e.g. acme/backend

# ── Webhook security ──────────────────────────────────────────────────────────
WEBHOOK_SECRET=change-me-to-random-32-chars

# ── Harness (used by harness_client.py to re-trigger pipelines) ───────────────
HARNESS_API_KEY=...
HARNESS_ACCOUNT_ID=...
HARNESS_ORG_ID=...
HARNESS_PROJECT_ID=...
HARNESS_PIPELINE_ID=coding-agent-pipeline

# ── Runtime ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
PORT=8000
